{
  "name": "@atomos/prime-style",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./src/styles/index.css",
    "./*": "./*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tailwindcss -i ./src/styles/index.css -o ./dist/styles.css",
    "dev": "tsc -p tsconfig.build.json --watch",
    "build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/styles.css --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "powershell -Command \"Remove-Item -Force -Recurse dist -ErrorAction SilentlyContinue; exit 0\""
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0"
  }
}
