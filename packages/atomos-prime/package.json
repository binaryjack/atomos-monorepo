{
  "name": "@atomos/prime",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "docs": "vite docs --port 3030",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "powershell -Command \"Remove-Item -Force -Recurse dist -ErrorAction SilentlyContinue; exit 0\""
  },
  "dependencies": {
    "@binaryjack/formular.dev": "workspace:*",
    "@atomos/structura-core": "workspace:*",
    "@atomos/prime-style": "workspace:*"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.2",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  }
}
